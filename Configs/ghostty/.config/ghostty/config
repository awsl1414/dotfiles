# --- 基础视觉与主题 ---
theme = "Catppuccin Macchiato"

# 原生滚动条
# 可选值: "system", "visible", "hidden"
scrollbar = "system"

# 现代模糊渲染与透明度
background-opacity = 0.9
background-blur = true


# --- 字体配置 ---
font-family = "Maple Mono NF CN"
font-family-italic = "Maple Mono NF CN Italic"
font-family-bold-italic = "Maple Mono NF CN Bold Italic"

# 禁用合成样式
font-synthetic-style = false

# 字体特性 (修复：使用逗号分隔的字符串以完美匹配 Ghostty 解析器)
font-feature = "calt,liga,-dlig"


# --- 光标与交互 ---
cursor-style = "underline"
cursor-style-blink = true

# 颜色配置：确保文字在光标下清晰可见
cursor-color = "cell-foreground"
cursor-text = "cell-background"
adjust-cursor-thickness = 2

# 交互行为
copy-on-select = true
scroll-to-bottom = "keystroke"
confirm-close-surface = false
focus-follows-mouse = true
mouse-hide-while-typing = true


# --- 窗口布局优化 ---
window-padding-x = 10
window-padding-y = 10
window-padding-balance = true
window-padding-color = "extend"


# --- 系统集成与优化 ---
shell-integration = "zsh"

# Shell 集成特性 (修复：同样使用纯字符串与逗号分隔)
shell-integration-features = "no-sudo,cursor,title"

window-subtitle = "working-directory"
image-storage-limit = 335544320


# --- macOS 平台专项推荐 ---
macos-titlebar-style = "native"
macos-option-as-alt = "left"
macos-non-native-fullscreen = true
macos-window-shadow = true
# 推荐：在系统 dock 栏使用与主题相关的动态图标效果
macos-icon = "official"


# --- Linux 平台专项推荐 ---
# 推荐：开启原生窗口装饰 (在使用 GNOME 时体验更好；若用 i3/Sway 建议设为 false)
window-decoration = true
# 推荐：利用 Linux 内核特性优化终端资源分配，避免高负载下卡顿
linux-cgroup = "always"


# --- 1.3.0 快捷键与 Quick Terminal (全局下拉终端) ---
# 全局唤起快捷键 (类似 Quake 模式)
keybind = "global:cmd+shift+g=toggle_quick_terminal"
quick-terminal-position = "top"
quick-terminal-animation-duration = 0.2

# 生产力快捷键
keybind = "cmd+f=start_search"
keybind = "cmd+d=new_split:right"
keybind = "cmd+shift+d=new_split:down"
keybind = "cmd+z=toggle_split_zoom"

# 标签页跳转
keybind = "cmd+1=goto_tab:1"
keybind = "cmd+2=goto_tab:2"
keybind = "cmd+3=goto_tab:3"
# Shell 集成功能（目前解决 ssh 乱码问题）
shell-integration-features = ssh-env, ssh-terminfo
